# Copy to .env (never commit .env). Values are examples only.

# Mastodon instance base URL (no trailing slash), e.g. https://mastodon.social
# PUBLIC_MASTODON_ORIGIN=

# OAuth app credentials from the instance (Development → New application)
# MASTODON_CLIENT_ID=
# MASTODON_CLIENT_SECRET=
# Optional redirect URI must match what you register, e.g. http://localhost:5173/oauth/callback
